*.pem
*.key
instances.json
.config

# Tests & dev tooling (not needed at runtime)
tests
.vscode
.idea
eslint.config.*
vitest.config.*

# Local-only / gitignored working dirs
research
qiita
venv_312

# Editor / OS noise
*.log
.DS_Store
npm-debug.log*
